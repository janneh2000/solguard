# ── solguard-notifiers ───────────────────────────────────────────────────────
# Shared secret with solguard-core. Both services must use the same value.
NOTIFIER_HMAC_SECRET=replace_with_32_byte_random_string

# Reject payloads whose timestamp is older than this (seconds).
MAX_CLOCK_SKEW_S=300

# ── Telegram ─────────────────────────────────────────────────────────────────
# Create a bot via @BotFather to get the token.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Discord ──────────────────────────────────────────────────────────────────
# Create a channel webhook under Server Settings → Integrations → Webhooks.
DISCORD_WEBHOOK_URL=
