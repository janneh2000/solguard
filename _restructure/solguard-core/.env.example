# ── solguard-core ────────────────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit the populated .env file.

# ── Solana RPC ───────────────────────────────────────────────────────────────
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_key_here

# ── Claude ───────────────────────────────────────────────────────────────────
# Optional. If absent, core falls back to the deterministic mock scorer.
ANTHROPIC_API_KEY=

# ── Webhook ingress auth ─────────────────────────────────────────────────────
# HMAC-SHA256 secret for /webhooks/helius — required in production.
HELIUS_WEBHOOK_SECRET=replace_with_32_byte_random_string

# ── Admin controls ───────────────────────────────────────────────────────────
SOLGUARD_ADMIN_TOKEN=replace_with_32_byte_random_string

# ── Notifier fanout (outbound) ───────────────────────────────────────────────
# Comma-separated list of solguard-notifiers (or compatible) receiver URLs.
# If empty, core runs alert-generation-only — no external notifications.
NOTIFIER_URLS=http://localhost:8001/alert
NOTIFIER_HMAC_SECRET=replace_with_32_byte_random_string
NOTIFIER_TIMEOUT_S=5

# ── CORS + SSE ───────────────────────────────────────────────────────────────
SOLGUARD_CORS_ORIGINS=https://solguard.vercel.app,http://localhost:3000,http://localhost:8080
MAX_SSE_CLIENTS=200

# ── Polling cadence ──────────────────────────────────────────────────────────
POLL_INTERVAL=30

# ── On-chain registry (optional) ─────────────────────────────────────────────
SOLGUARD_PROGRAM_ID=5kkaYGaXECsngVohp3Z7NdDnxpfatTqSsmMVpsnngZFM
SOLANA_KEYPAIR_PATH=
