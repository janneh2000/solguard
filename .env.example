# ── SolGuard Environment Variables ─────────────────────────────────
# Copy this to .env and fill in your values. NEVER commit your .env.

# ── Required ────────────────────────────────────────────────────────
# Anthropic API key — required for AI risk scoring (falls back to mock)
ANTHROPIC_API_KEY=your_key_here

# Helius RPC URL — recommended for reliable Solana mainnet access
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ── Security (STRONGLY recommended for production) ─────────────────
# Shared secret for authenticating Helius webhook POSTs.
# Either sent as `X-Helius-Signature: <hmac-sha256(body)>` or `Authorization: Bearer <secret>`
HELIUS_WEBHOOK_SECRET=

# Admin token — gates /api/trigger-test. Leave empty to disable the endpoint entirely.
SOLGUARD_ADMIN_TOKEN=

# Comma-separated list of allowed CORS origins for the public API.
SOLGUARD_CORS_ORIGINS=https://solguard.vercel.app,http://localhost:3000

# Max concurrent SSE clients.
MAX_SSE_CLIENTS=200

# ── Notifications (optional) ───────────────────────────────────────
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Polling / monitoring ───────────────────────────────────────────
POLL_INTERVAL=30

# ── On-chain registry ──────────────────────────────────────────────
# Set after `anchor deploy`.
SOLGUARD_PROGRAM_ID=5kkaYGaXECsngVohp3Z7NdDnxpfatTqSsmMVpsnngZFM
# Path to a funded keypair on the cluster (e.g. ~/.config/solana/devnet.json)
SOLANA_KEYPAIR_PATH=
