# ── SolGuard Environment Variables ─────────────────────────────────
# Copy this to .env and fill in your values

# Anthropic API key (required for AI risk scoring)
ANTHROPIC_API_KEY=your_key_here

# Helius RPC URL (recommended for reliable Solana access + webhooks)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Discord webhook URL (optional — for Discord alerts)
DISCORD_WEBHOOK_URL=

# Telegram bot (optional — for Telegram alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Polling interval in seconds (default: 30)
POLL_INTERVAL=30
